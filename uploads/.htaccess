# Cegah eksekusi PHP di folder uploads (defense-in-depth kalau ada file
# berbahaya lolos validasi MIME/magic-bytes di FileUploader.php).

# Apache 2.4+
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php|php\d|phtml|phar|pl|py|cgi|sh)$">
        Require all denied
    </FilesMatch>
</IfModule>

# Apache 2.2 (fallback)
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|php\d|phtml|phar|pl|py|cgi|sh)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# Matikan engine PHP kalau module php aktif di config Apache
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

Options -Indexes -ExecCGI
