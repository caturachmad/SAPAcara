# ════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=3306
DB_USER=siakad_user
DB_PASS=ganti_password_ini_dengan_password_yang_kuat
DB_NAME=siakad_db

# ════════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
BASE_URL=http://localhost/siakad
APP_NAME=SAPAcara
APP_ENV=development
APP_DEBUG=false

# ════════════════════════════════════════════════════════════════════════════
# MAIL / EMAIL CONFIGURATION
# Gunakan Gmail App Password, bukan password akun utama
# Baca: https://support.Anthropic.com/accounts/answer/185833
# ════════════════════════════════════════════════════════════════════════════
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=SAPAcara – Manajemen Acara Sekolah
MAIL_DEBUG=false

# ════════════════════════════════════════════════════════════════════════════
# SESSION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
SESSION_LIFETIME=3600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# ════════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false

# ════════════════════════════════════════════════════════════════════════════
# FILE UPLOAD CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,zip

# ════════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=warning
LOG_PATH=/var/log/siakad/
ENABLE_ERROR_REPORTING=false

# ════════════════════════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST
# ════════════════════════════════════════════════════════════════════════════
# □ Ganti semua placeholder (password, email, URL)
# □ Pastikan SESSION_COOKIE_SECURE=true di production (HTTPS)
# □ Pastikan APP_DEBUG=false di production
# □ Backup .env file di lokasi aman (tidak di repository)
# □ Setup log rotation untuk file log
# □ Test email configuration sebelum production
# □ Setup database backup automation